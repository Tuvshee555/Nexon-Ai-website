# ─────────────────────────────────────────────────────────────────────────────
# Nexon Nova — Environment Variables
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Public contact details (shown in the UI) ─────────────────────────────────
NEXT_PUBLIC_PHONE_NUMBER=+976 8618 5769
NEXT_PUBLIC_PHONE_RAW=+97686185769
NEXT_PUBLIC_EMAIL_ADDRESS=nexondigitalnova@gmail.com
NEXT_PUBLIC_INSTAGRAM_LINK=https://www.instagram.com/nexon_nova/
NEXT_PUBLIC_FACEBOOK_LINK=https://www.facebook.com/profile.php?id=61582430194143
# Add your Telegram link here once you have it:
# NEXT_PUBLIC_TELEGRAM_LINK=https://t.me/yourhandle

# ── Telegram bot notification ─────────────────────────────────────────────────
# 1. Create a bot via @BotFather on Telegram → get the token below
# 2. Add the bot to your group or start a chat → get the chat_id
#    (tip: send a message then visit https://api.telegram.org/bot<TOKEN>/getUpdates)
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxyz
TELEGRAM_CHAT_ID=-100123456789

# ── Database (optional — replace JSON file storage with a real DB) ────────────
# Uncomment and configure when you are ready to connect Prisma / Supabase / etc.
# DATABASE_URL=postgresql://user:password@localhost:5432/nexonnova

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
